# =============================================================================
#  The Swarm — Environment Variables
#  Copy this file to .env and fill in your real values before running.
# =============================================================================

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
# Optional – only needed if you use SSO or cross-account roles
# AWS_SESSION_TOKEN=

# ─── ECS / Fargate ────────────────────────────────────────────────────────────
SWARM_ECS_CLUSTER=swarm-cluster

# ECS task definition ARNs (created after you push Docker images to ECR)
SWARM_EMAIL_TASK_DEF=arn:aws:ecs:us-east-1:123456789012:task-definition/swarm-email-node:1
SWARM_SEO_TASK_DEF=arn:aws:ecs:us-east-1:123456789012:task-definition/swarm-seo-node:1
SWARM_DM_TASK_DEF=arn:aws:ecs:us-east-1:123456789012:task-definition/swarm-dm-node:1
SWARM_VOICE_TASK_DEF=arn:aws:ecs:us-east-1:123456789012:task-definition/swarm-voice-node:1
SWARM_CONTENT_TASK_DEF=arn:aws:ecs:us-east-1:123456789012:task-definition/swarm-content-node:1
SWARM_SCRAPER_TASK_DEF=arn:aws:ecs:us-east-1:123456789012:task-definition/swarm-scraper-node:1
SWARM_ANALYTICS_TASK_DEF=arn:aws:ecs:us-east-1:123456789012:task-definition/swarm-analytics-node:1

# VPC subnets for Fargate tasks (comma-separated)
SWARM_SUBNET_IDS=subnet-xxxxxxxxxxxxxxxxx,subnet-yyyyyyyyyyyyyyyyy
# Security group(s) for Fargate tasks (comma-separated)
SWARM_SECURITY_GROUP_IDS=sg-xxxxxxxxxxxxxxxxx

# ─── SQS Queue URLs ───────────────────────────────────────────────────────────
SWARM_COMMANDER_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/swarm-commander-queue
SWARM_EMAIL_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/swarm-email-queue
SWARM_SEO_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/swarm-seo-queue
SWARM_DM_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/swarm-dm-queue
SWARM_VOICE_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/swarm-voice-queue
SWARM_CONTENT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/swarm-content-queue
SWARM_SCRAPER_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/swarm-scraper-queue
SWARM_ANALYTICS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/swarm-analytics-queue

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Amazon SES (email_node) ──────────────────────────────────────────────────
# No API key needed — SES uses your AWS credentials above
SES_FROM_EMAIL=you@yourdomain.com
SES_FROM_NAME=Your Name
SES_REPLY_TO=you@yourdomain.com

# ─── (Twilio/voice removed — not used) ───────────────────────────────────────
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
# Public URL to your call-status webhook (ngrok / ALB / Lambda URL)
TWILIO_STATUS_CALLBACK_URL=https://your-domain.com/webhooks/call-status

# ─── ElevenLabs (voice_node) ──────────────────────────────────────────────────
ELEVENLABS_API_KEY=
# Find voice IDs at https://api.elevenlabs.io/v1/voices
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ─── X / Twitter (content_node, dm_node) ─────────────────────────────────────
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=

# ─── LinkedIn (content_node, dm_node) ────────────────────────────────────────
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=urn:li:person:XXXXXXXXXX

# ─── Reddit (content_node, dm_node, scraper_node) ────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# ─── Apollo.io (scraper_node) ─────────────────────────────────────────────────
APOLLO_API_KEY=

# ─── Hunter.io (scraper_node) ─────────────────────────────────────────────────
HUNTER_API_KEY=

# ─── SerpAPI (seo_node) ───────────────────────────────────────────────────────
SERPAPI_API_KEY=

# ─── WordPress (seo_node) ─────────────────────────────────────────────────────
WP_BASE_URL=https://your-site.com
WP_USERNAME=admin
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ─── Slack (analytics_node notifications) ────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# ─── Swarm Bootstrap ─────────────────────────────────────────────────────────
# JSON array of campaign goal objects passed to Commander on first start
SWARM_BOOTSTRAP_GOALS=[{"goal":"Generate 1000 qualified leads","channel":"email,scraper","dailyBudget":50},{"goal":"Increase organic traffic 30%","channel":"seo,content","dailyBudget":30}]

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
# Set to "production" to disable pino-pretty and emit JSON logs
NODE_ENV=development
